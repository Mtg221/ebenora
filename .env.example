# Copiez ce fichier en `.env` et remplissez avec les valeurs de votre projet Supabase
# (Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre_clef_anon_publique

# ── Statistiques admin (fonction serverless /api/analytics) ──
# À définir dans Vercel → Project Settings → Environment Variables (NON exposées au client).
# Web Analytics doit être activé sur le projet Vercel.
VERCEL_TOKEN=vercel_access_token          # Account Settings → Tokens
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxx        # Project Settings → General
VERCEL_TEAM_ID=team_xxxxxxxxxxxx          # uniquement si le projet appartient à une équipe
SUPABASE_URL=https://VOTRE-PROJET.supabase.co   # même valeur que VITE_SUPABASE_URL (côté serveur)
SUPABASE_ANON_KEY=votre_clef_anon_publique      # même valeur que VITE_SUPABASE_ANON_KEY
